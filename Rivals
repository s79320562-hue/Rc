-- Now that Tabs list is populated we can define ApplyAccent properly.
-- It walks AccentRegistry (all registered elements) AND updates tab icon
-- tints so the active tab icon stays accent and the rest go dark.
ApplyAccent = function(newColor)
	CFG.AccentColor = newColor
	for _, entry in ipairs(AccentRegistry) do
		if entry.obj and entry.obj.Parent then
			entry.obj[entry.prop] = newColor
		end
	end
	for _, t in ipairs(Tabs) do
		t.Icon.ImageColor3 = t.Page.Visible and newColor or CFG.TextDark
	end
end

