				Text               = cfg.Name,
				TextColor3         = CFG.TextDark,
				TextSize           = 11,
				Font               = CFG.Font,
				BackgroundTransparency = 1,
				Size               = UDim2.new(1, 0, 0, 15),
				TextXAlignment     = Enum.TextXAlignment.Left,
			})

			local valLabel = Create("TextLabel", {
				Parent             = frame,
				Text               = value .. (cfg.Unit or ""),
				TextColor3         = CFG.TextDark,
				TextSize           = 11,
				Font               = CFG.Font,
				BackgroundTransparency = 1,
				Size               = UDim2.new(1, 0, 0, 15),
				TextXAlignment     = Enum.TextXAlignment.Right,
			})

			local bg = Create("Frame", {
				Parent           = frame,
				Size             = UDim2.new(1, 0, 0, 6),
				Position         = UDim2.new(0, 0, 0, 20),
				BackgroundColor3 = CFG.SecondaryColor,
				BorderSizePixel  = 0,
			}, {
				Create("UIStroke", { Color = CFG.StrokeColor }),
				Create("UICorner", { CornerRadius = UDim.new(1, 0) }),
			})

			local fill = Create("Frame", {
				Parent           = bg,
				Size             = UDim2.new(0, 0, 1, 0),
				BackgroundColor3 = CFG.AccentColor,
			}, { Create("UICorner", { CornerRadius = UDim.new(1, 0) }) })
			RegisterAccent(fill, "BackgroundColor3")

			local function applyInput(input)
				local pct  = math.clamp((input.Position.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
				value      = math.floor(cfg.Min + (cfg.Max - cfg.Min) * pct)
				fill.Size  = UDim2.new(pct, 0, 1, 0)
				valLabel.Text = value .. (cfg.Unit or "")
				if cfg.Flag then Library.Flags[cfg.Flag] = value end
				if cfg.Callback then cfg.Callback(value) end
			end

			frame.InputBegan:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1
					or i.UserInputType == Enum.UserInputType.Touch then
					dragging = true
					applyInput(i)
				end
