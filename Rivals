-- ============================================================
--  File I/O helpers  (executor API, wrapped so script doesn't
--  crash if running in an environment that lacks them)
-- ============================================================

local CONFIG_FOLDER = "RC_Configs"
local THEME_FILE    = CONFIG_FOLDER .. "/theme.json"

local function ensureFolder()
	if type(makefolder) ~= "function" then return false end
	local ok, exists = pcall(function()
		return type(isfolder) == "function" and isfolder(CONFIG_FOLDER)
	end)
	if not (ok and exists) then
		pcall(makefolder, CONFIG_FOLDER)
	end
	return true
end

local function safeWrite(path, data)
	if type(writefile) ~= "function" then return false end
	return pcall(writefile, path, data)
end

local function safeRead(path)
	if type(readfile) ~= "function" then return nil end
	local ok, data = pcall(readfile, path)
	return ok and data or nil
end

local function safeExists(path)
	if type(isfile) ~= "function" then return false end
	local ok, result = pcall(isfile, path)
	return ok and result == true
end

local function safeDelete(path)
	if type(delfile) == "function" then pcall(delfile, path) end
end

-- ============================================================
--  Config save / load
-- ============================================================

local function SaveConfig(name)
	if not name or name == "" then
		Library:Notify("Enter a config name first", "warning")
		return
	end
	if not ensureFolder() then
		Library:Notify("writefile not available", "warning")
		return
	end
	local path    = CONFIG_FOLDER .. "/" .. name .. ".json"
	local encoded = HttpService:JSONEncode(Library.Flags)
	if safeWrite(path, encoded) then
		Library:Notify("Saved: " .. name, "success")
	else
		Library:Notify("Save failed – check executor file permissions", "warning")
	end
end

local function LoadConfig(name)
	if not name or name == "" then
		Library:Notify("Enter a config name first", "warning")
		return nil
	end
	local path = CONFIG_FOLDER .. "/" .. name .. ".json"
	if not safeExists(path) then
		Library:Notify("Config not found: " .. name, "warning")
		return nil
	end
	local raw = safeRead(path)
	if not raw then
		Library:Notify("Could not read file", "warning")
		return nil
	end
	local ok, tbl = pcall(HttpService.JSONDecode, HttpService, raw)
	if not ok or type(tbl) ~= "table" then
		Library:Notify("Config file is corrupted", "warning")
		return nil
	end
	Library.Flags = tbl
	Library:Notify("Loaded: " .. name, "success")
	return tbl
end

local function SaveTheme()
	if not ensureFolder() then return end
	local r = math.round(CFG.AccentColor.R * 255)
	local g = math.round(CFG.AccentColor.G * 255)
	local b = math.round(CFG.AccentColor.B * 255)
	safeWrite(THEME_FILE, HttpService:JSONEncode({ r = r, g = g, b = b }))
end

-- forward-declared; defined after Tabs are built
local ApplyAccent

local function LoadTheme()
	if not safeExists(THEME_FILE) then return end
	local raw = safeRead(THEME_FILE)
	if not raw then return end
	local ok, tbl = pcall(HttpService.JSONDecode, HttpService, raw)
	if ok and tbl and tbl.r then
		ApplyAccent(Color3.fromRGB(tbl.r, tbl.g, tbl.b))
	end
end

